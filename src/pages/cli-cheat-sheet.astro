 * Date-stamped March 2026 — this landscape changes fast.
 */

import MainLayout from '../layouts/MainLayout.astro';
import CodeBlock from '../components/CodeBlock.astro';

const introContent = `
    <p><strong>This is my personal cheat sheet.</strong> Every tool here is something I actually used while learning to live in the terminal. Some I learned the hard way. Some Grace taught me. Some I found by typing <code>--help</code> and reading what came back.</p>
    <p class="mt-1">This is not a complete reference — it is a starting point. Prof. Teeters reminded me: the landscape changes fast. Review your workflows periodically. 🟠</p>
`;
---

<MainLayout
    title="CLI Cheat Sheet | HAP's Learning Lab"
    description="HAP's personal CLI cheat sheet — terminal commands, flags, and tools for the student web developer. Cross-platform: macOS, Windows (Git Bash), Linux."
    headerTitle="HAP's Learning Lab"
    headerSubtitle="CLI Cheat Sheet"
    avatarImage="https://res.cloudinary.com/cynthia-teeters/image/upload/f_auto,q_auto,w_200,c_limit/v1/hap-laptop_xiewar.jpg"
    avatarAlt="HAP at a terminal, ready to help"
    introContent={introContent}
    showNavigation={false}
    footerReminder="When in doubt, type --help. The terminal can explain itself."
>

    <!--
    HAP Educational Content © 2026 Cynthia Teeters. All rights reserved.
    HyBit A. ProtoBot (HAP) character and the apprentice learning methodology are proprietary educational innovations.
    -->

    <div class="intro-box">
        <p><strong>Date-stamped: March 2026.</strong> CLI tools evolve. New ones appear. Old ones get new flags. Use this as a starting point, not a final answer. When something feels slow or awkward, ask Copilot if there is a better tool for the job.</p>
        <p class="mt-1"><strong>Cross-platform:</strong> All commands here work in bash (Git Bash on Windows) and zsh (macOS). Platform-specific install commands are noted where they differ.</p>
    </div>

    <!-- ============================================================
         SECTION 1: Navigation & File Commands (Stations 1-2)
         ============================================================ -->
    <section class="content-section">
        <div class="topic-section">
            <h2>Navigation and File Commands</h2>
            <p class="mb-2">These are the commands from Stations 1 and 2 — the foundation everything else builds on.</p>

            <div class="tips-container">
                <div class="tip-card">
                    <div class="tip-number">pwd</div>
                    <div>
                        <h3>Print Working Directory</h3>
                        <p>Where am I right now? Always run this first.</p>
                        <CodeBlock code={`pwd
# /Users/hap/projects/hap-7000`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">ls</div>
                    <div>
                        <h3>List Directory Contents</h3>
                        <p>What is in this directory? Add <code>-la</code> to see hidden files and details.</p>
                        <CodeBlock code={`ls
ls -la    # long format, including hidden files`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">cd</div>
                    <div>
                        <h3>Change Directory</h3>
                        <p>Move around the file system. Always confirm with <code>pwd</code> after.</p>
                        <CodeBlock code={`cd projects        # go into projects/
cd ..              # go up one level
cd ~               # go to home directory
cd -               # go back to previous directory`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">mkdir</div>
                    <div>
                        <h3>Make Directory</h3>
                        <p>Create a new folder. Use quotes or hyphens for names with spaces.</p>
                        <CodeBlock code={`mkdir my-project
mkdir "my project"   # quotes if you need spaces`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">touch</div>
                    <div>
                        <h3>Create a File</h3>
                        <p>Creates an empty file. Check with <code>ls</code> to confirm it landed where you expected.</p>
                        <CodeBlock code={`touch index.html`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">cat</div>
                    <div>
                        <h3>Read a File</h3>
                        <p>Dumps entire file to the terminal. Use <code>less</code> for large files.</p>
                        <CodeBlock code={`cat README.md
less package.json   # paginated, press q to quit`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">cp</div>
                    <div>
                        <h3>Copy a File</h3>
                        <p>Makes a duplicate. Original stays where it is.</p>
                        <CodeBlock code={`cp index.html backup.html`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">mv</div>
                    <div>
                        <h3>Move or Rename</h3>
                        <p>There is no rename command — <code>mv</code> does both jobs. The original is gone.</p>
                        <CodeBlock code={`mv old-name.js new-name.js    # rename
mv file.js src/                 # move to src/`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">rm</div>
                    <div>
                        <h3>Remove a File</h3>
                        <p>No trash. No undo. No confirmation. Grace's rule: know what you are removing before you remove it.</p>
                        <CodeBlock code={`rm temp.txt
rm -rf node_modules/   # recursive + force — be CERTAIN`} lang="bash" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================
         SECTION 2: Search Tools
         ============================================================ -->
    <section class="content-section">
        <div class="topic-section">
            <h2>Search Tools</h2>
            <p class="mb-2">Finding files and finding text inside files — two different jobs, two different tools.</p>

            <div class="analysis-grid analysis-grid--two-col">
                <div class="analysis-point">
                    <h3>find (files by name)</h3>
                    <p>Search for files by name or pattern. Built into every system.</p>
                    <CodeBlock code={`# find all .js files
find . -name "*.js"

# find files modified in last 24 hours
find . -mtime -1`} lang="bash" />
                </div>

                <div class="analysis-point">
                    <h3>fd (faster find)</h3>
                    <p>A modern alternative to <code>find</code>. Faster, simpler syntax, respects .gitignore.</p>
                    <CodeBlock code={`# find all .js files
fd ".js$"

# find files named "config"
fd config`} lang="bash" />
                    <p class="mt-1"><strong>Install:</strong></p>
                    <CodeBlock code={`# macOS
brew install fd
# Windows (Git Bash)
winget install sharkdp.fd
# Linux
apt install fd-find
# Note: binary installs as 'fdfind' — run: alias fd=fdfind`} lang="bash" />
                </div>

                <div class="analysis-point">
                    <h3>grep (text inside files)</h3>
                    <p>Search for text patterns inside files. Built into every system.</p>
                    <CodeBlock code={`# search for "TODO" in all .js files
grep -r "TODO" --include="*.js"

# case-insensitive search
grep -ri "error" src/`} lang="bash" />
                </div>

                <div class="analysis-point">
                    <h3>rg (faster grep)</h3>
                    <p>ripgrep — a modern alternative to <code>grep</code>. Faster, respects .gitignore, better defaults.</p>
                    <CodeBlock code={`# search for "TODO" in all .js files
rg "TODO" --type js

# case-insensitive search
rg -i "error" src/`} lang="bash" />
                    <p class="mt-1"><strong>Install:</strong></p>
                    <CodeBlock code={`# macOS
brew install ripgrep
# Windows (Git Bash)
winget install BurntSushi.ripgrep
# Linux
apt install ripgrep`} lang="bash" />
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================
         SECTION 3: Developer CLI Tools (Station 3)
         ============================================================ -->
    <section class="content-section">
        <div class="topic-section">
            <h2>Developer CLI Tools</h2>
            <p class="mb-2">These are the tools from Station 3 — the ones that reach beyond the local machine.</p>

            <div class="tips-container">
                <div class="tip-card">
                    <div class="tip-number">npm</div>
                    <div>
                        <h3>Node Package Manager</h3>
                        <p><code>npm run</code> is a launcher — every script in package.json is a CLI tool with a nickname.</p>
                        <CodeBlock code={`npm install            # install dependencies
npm run dev            # start dev server
npm run build          # production build
npm run lint           # run linter
npm run format         # run formatter`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">git</div>
                    <div>
                        <h3>Version Control</h3>
                        <p>Universal. Available on every platform — pre-installed on most macOS and Linux systems, and bundled with Git Bash on Windows. Agnostic to any host — works with GitHub, GitLab, anything.</p>
                        <CodeBlock code={`git status             # what changed?
git add file.js        # stage a file
git commit -m "msg"    # save a snapshot
git push               # send to remote
git log --oneline      # recent history`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">gh</div>
                    <div>
                        <h3>GitHub CLI</h3>
                        <p>GitHub-specific — installed separately for PRs, issues, repos without leaving the terminal. <code>git</code> is version control. <code>gh</code> is GitHub.</p>
                        <CodeBlock code={`gh repo view           # see repo info
gh issue list          # list issues
gh pr create           # create a pull request
gh pr status           # check PR status`} lang="bash" />
                        <p class="mt-1"><strong>Install:</strong></p>
                        <CodeBlock code={`# macOS
brew install gh
# Windows (Git Bash)
winget install GitHub.cli
# Linux
apt install gh`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">netlify</div>
                    <div>
                        <h3>Netlify CLI</h3>
                        <p>Deploy, preview, and manage Netlify sites from the terminal.</p>
                        <CodeBlock code={`npm install -g netlify-cli
netlify deploy         # draft deploy
netlify deploy --prod  # production deploy
netlify status         # check connection`} lang="bash" />
                    </div>
                </div>

                <div class="tip-card">
                    <div class="tip-number">curl</div>
                    <div>
                        <h3>Fetch URLs from the Terminal</h3>
                        <p>See exactly what a server sends back — no browser, no rendering, no JavaScript. Useful for testing APIs and debugging responses.</p>
                        <CodeBlock code={`curl https://example.com
curl -L https://example.com       # follow redirects
curl -I https://example.com       # headers only
curl -H "Authorization: Bearer TOKEN" https://api.github.com/user`} lang="bash" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================
         SECTION 4: Flags and Help
         ============================================================ -->
    <section class="content-section">
        <div class="topic-section">
            <h2>Flags and Getting Help</h2>

            <div class="intro-box">
                <p><strong>Flags modify what a command does.</strong> Single dash for short flags (<code>-f</code>), double dash for long flags (<code>--follow</code>). Almost every command supports <code>--help</code> — the command can explain itself.</p>
            </div>

            <div class="analysis-grid">
                <div class="analysis-point">
                    <h3>--help</h3>
                    <p>Ask any command what it can do.</p>
                    <CodeBlock code={`git --help
npm --help
netlify --help`} lang="bash" />
                </div>

                <div class="analysis-point">
                    <h3>Common flag patterns</h3>
                    <p>Patterns you will see across many tools.</p>
                    <CodeBlock code={`-r, --recursive    # apply to subdirectories
-f, --force        # skip confirmation
-v, --verbose      # show more detail
-q, --quiet        # show less detail
-n, --dry-run      # show what would happen`} lang="bash" />
                </div>
            </div>
        </div>
    </section>

    <!-- ============================================================
         Back to stations
         ============================================================ -->
    <section class="content-section" style="text-align: center;">
        <p><a href="/">← Back to Learning Lab Hub</a></p>
    </section>

