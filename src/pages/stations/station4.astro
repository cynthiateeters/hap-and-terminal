---
import StationLayout from '../../layouts/StationLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const introContent = `
    <p><strong>Welcome to Station 4!</strong> I had been watching Copilot make decisions for three stations now — running commands, choosing file structures, writing code a certain way. It all worked, but I never understood <em>why</em> it made those choices. I assumed it was some kind of built-in intelligence.</p>
    <p class="mt-1">Then Grace said something that changed everything. She did not even look up from her screen.</p>
    <p class="mt-1">This is the station where I stopped blaming Copilot and started reading what it reads. 🟠</p>
`;
---

<StationLayout
    stationNumber={4}
    title="The Terminal Has a Memory"
    subtitle="Context engineering — teaching the agent what you already know"
    description="HAP discovers AGENTS.md, learns how Copilot reads workspace context, and changes agent behavior by changing what the agent reads."
    avatarImage="https://res.cloudinary.com/cynthia-teeters/image/upload/f_auto,q_auto,w_200,c_limit/v1/hap-laptop_xiewar.jpg"
    avatarAlt="HAP at a laptop, studying AGENTS.md"
    introContent={introContent}
    nextStationTitle="The Terminal Gets a Brain"
    footerReminder="I did not change Copilot. I changed what it reads. That is the whole thing."
    labName="Living in the Terminal"
>

